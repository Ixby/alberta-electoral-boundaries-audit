__pycache__/
*.pyc
*.pyo

# Build-pipeline intermediate outputs — only the merged report_public.pdf
# is the published artefact; article.pdf and article.html are regenerated
# on every build and create commit noise.
article.pdf
article.html
archive/
.env
venv/
.venv/
*.egg-info/
dist/
build/
.DS_Store
.temp/
cache/
logs/
private/
maps/pdf_previews/
analysis/scripts/*.csv

# Pipeline-internal scratch directories — final outputs are written
# elsewhere and these are deleted on successful completion.
data/shapefiles/derived/_perfecter_checkpoints/
data/mcmc_checkpoints_*/
# But preserve the per-chain metric CSVs via Git LFS — these are the
# actual numerical record of every ReCom step in the published ensembles.
!data/mcmc_checkpoints_*/chain*_samples.csv

# Orphan output directory — scripts that target data/maps/ sometimes land
# here when the working directory is wrong; the canonical copy lives in
# data/maps/.
/maps/

# MCMC raw sample CSVs >100MB — keep percentiles + diagnostics + log instead
data/v0_1_mcmc_ensemble_samples_*.csv

# OSM debug-only raw Overpass JSONs — the GPKG (3x smaller) is the
# canonical committed cache; the JSON preserves raw tag dictionaries for
# future filtering work and is regenerated on demand by
# analysis/scripts/_fetch_osm_natural.py.
data/osm/*.json

# Outreach emails — drafts and sent log; never committed (contain personal contact details)
emails/

# Scratch / scratchpad scripts at repo root (e.g. scratch_lassos.py).
# These are PO working files / one-off probes — not part of the canonical
# pipeline. Canonical scripts live under analysis/scripts/. Add specific
# scratch files explicitly only if you want them tracked.
/scratch_*.py
